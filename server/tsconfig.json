{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"strict": true,
		"moduleResolution": "Bundler",
		"esModuleInterop": true,
		"skipLibCheck": true,
		"outDir": "dist",
		"emitDeclarationOnly": true,
		"composite": true,
		"rootDir": ".",
		"types": ["node"],
		"jsx": "react-jsx",
		"paths": {
			"~/*": ["./src/*"],
			"~/routers": ["./src/trpc/routers"],
			"@prisma/client": ["./prisma/generated/prisma/client"]
		}
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.tsx",
		"prisma.config.ts",
		"src/seed.ts",
		"prisma/generated/**/*.ts"
	],
	"exclude": ["node_modules", "dist"]
}
